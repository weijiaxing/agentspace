# Agent Space backend mode
# mock | openai-compatible
AGENT_BACKEND_MODE=mock

# Required when AGENT_BACKEND_MODE=openai-compatible
AGENT_BACKEND_BASE_URL=https://api.openai.com/v1
AGENT_BACKEND_API_KEY=your_api_key_here
AGENT_BACKEND_MODEL=gpt-4o-mini

# Optional system prompt override
AGENT_BACKEND_SYSTEM_PROMPT=You are Andy, an operator assistant inside Agent Space. Be direct, useful, and concise.

# 3D model loading
# Set to true after you place public/models/andy.glb
NEXT_PUBLIC_AGENT_MODEL_ENABLED=false
